# TurnFlow local environment example
# Copy this file to ".env" and fill in the real values locally.

DATABASE_URL=sqlite:///./turnflow.db
SECRET_KEY=change-me-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

REPORTS_DIR=reports

EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_SUBJECT_PREFIX=OKÚA Jardín Biosonoro · 
EMAIL_LOGO_PATH=static/okua-logo.png
CHECK_EMAIL_INTERVAL_SECONDS=60
